{
  "name": "easy-replace-in-files",
  "version": "1.0.5",
  "description": "CLI to find and replace in files via a JSON config. Supports globs, regex, and placeholders (e.g. $$package__version$$, $$ENV_VAR$$). Great for version bumps and build-time replacements.",
  "keywords": [
    "replace",
    "find-replace",
    "search-replace",
    "cli",
    "config",
    "glob",
    "regex",
    "placeholders",
    "version-bump",
    "build"
  ],
  "files": [
    "index.js"
  ],
  "homepage": "https://github.com/ernilambar/easy-replace-in-files#readme",
  "bugs": {
    "url": "https://github.com/ernilambar/easy-replace-in-files/issues"
  },
  "license": "MIT",
  "author": "Nilambar Sharma <nilambar@outlook.com> (https://github.com/ernilambar)",
  "main": "index.js",
  "type": "module",
  "bin": "./index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ernilambar/easy-replace-in-files.git"
  },
  "scripts": {
    "lint": "standard",
    "format": "standard --fix",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "read-pkg-up": "^10.1.0",
    "replace-in-file": "^8.4.0",
    "unixify": "^1.0.0"
  },
  "devDependencies": {
    "standard": "^17.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "standard": {
    "globals": []
  }
}
